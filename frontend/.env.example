# База API. В деве оставь /api — Vite проксирует /api → backend (vite.config.ts),
# браузер видит один origin, CORS не нужен.
VITE_API_BASE_URL=/api

# Куда проксировать /api в деве (если backend не на localhost:3100):
# VITE_API_PROXY_TARGET=http://localhost:3100

# Прямое обращение к backend без прокси (напр. отдельный домен) — укажи абсолютный URL.
# Тогда нужен CORS на бэкенде: API__CORS_ORIGINS='["http://localhost:5173"]'.
# VITE_API_BASE_URL=http://localhost:3100

# Локальная разработка (ENV=local — значение по умолчанию).

# Отдельная локальная БД (копия рабочей — с тестовым аккаунтом).
DATABASE__URL=sqlite+aiosqlite:///./data/ssau_schedule_bot.local.db

# Valkey: локальный, порт проброшен на хост через docker compose.
VALKEY__HOST=127.0.0.1
VALKEY__PORT=6379
VALKEY__DB=0

# Логи: максимально подробно и читаемо в консоли (text, не json).
LOGGING__LEVEL=DEBUG
LOGGING__FORMAT=text

# Метрики Prometheus. Порты: API HTTP 3100, bot 3101, worker 3102, API metrics 3103.
METRICS__ENABLED=true
METRICS__HOST=0.0.0.0
METRICS__PORT=3103
TELEGRAM__METRICS_PORT=3101
WORKERS__METRICS_PORT=3102

# REST API (админ-ручки).
API__HOST=0.0.0.0
API__PORT=3100
API__METRICS_PORT=3103

# Telemetry (OTLP) и алерты — выключены.
TELEMETRY__ENABLED=false
ALERTS__ENABLED=false

# Без Fernet-ключа разрешаем plaintext-шифр паролей (удобно локально).
SECURITY__ALLOW_PLAINTEXT=true

# Прокси для Telegram (если нужен):
# TELEGRAM__PROXY_URL=http://127.0.0.1:7890

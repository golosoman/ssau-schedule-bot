# Local overrides (dev machine). ENV=local (default).

# Без Fernet-ключа разрешаем plaintext-шифр паролей (удобно локально).
SECURITY__ALLOW_PLAINTEXT=true

# Valkey берётся из common.env (127.0.0.1) — поднимай его через
# `make create-environment` (порт проброшен на хост).

# TELEGRAM__PROXY_URL=http://127.0.0.1:7890

# Dev / staging (ENV=dev).

# Отдельная dev-БД.
DATABASE__URL=sqlite+aiosqlite:///./data/ssau_schedule_bot.dev.db

# Valkey: локальный, DB=1 — изоляция кэша от local на той же машине.
VALKEY__HOST=127.0.0.1
VALKEY__PORT=6379
VALKEY__DB=1

# Логи: подробно (DEBUG), но в prod-формате json (под агрегаторы).
LOGGING__LEVEL=DEBUG
LOGGING__FORMAT=json

# Метрики Prometheus. Порты: API HTTP 3100, bot 3101, worker 3102, API metrics 3103.
METRICS__ENABLED=true
METRICS__HOST=0.0.0.0
METRICS__PORT=3103
TELEGRAM__METRICS_PORT=3101
WORKERS__METRICS_PORT=3102

# REST API (админ-ручки).
API__HOST=0.0.0.0
API__PORT=3100
API__METRICS_PORT=3103

# Telemetry (OTLP) и алерты — выключены.
TELEMETRY__ENABLED=false
ALERTS__ENABLED=false

# Без Fernet-ключа разрешаем plaintext-шифр паролей.
SECURITY__ALLOW_PLAINTEXT=true

# Чаще опрашиваем — удобнее тестировать уведомления:
# WORKERS__NOTIFICATION_POLL_INTERVAL_SECONDS=30

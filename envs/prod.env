# Prod overrides (docker deployment). ENV=prod.

# Valkey доступен по имени docker-сервиса (см. docker-compose.yaml).
# VALKEY__HOST=valkey

# Продовая SQLite-БД для docker-сервисов.
DATABASE__URL=sqlite+aiosqlite:///./data/ssau_schedule_bot.prod.db

# В проде шифр паролей — только Fernet (ключ в sensitive.env),
# plaintext не разрешаем (SECURITY__ALLOW_PLAINTEXT не задаём -> false).

# Боевая БД (пример — Postgres):
# DATABASE__URL=postgresql+asyncpg://user:pass@host:5432/ssau_schedule_bot

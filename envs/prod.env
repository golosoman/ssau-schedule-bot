# Прод (docker-деплой, ENV=prod).

# Valkey: host задаёт docker-compose (VALKEY__HOST=valkey, имя сервиса) —
# он одинаков для любого ENV в docker. Здесь — только порт и номер БД.
VALKEY__PORT=6379
VALKEY__DB=0

# Продовая SQLite-БД для docker-сервисов.
DATABASE__URL=sqlite+aiosqlite:///./data/ssau_schedule_bot.prod.db
# Боевая БД (пример — Postgres):
# DATABASE__URL=postgresql+asyncpg://user:pass@host:5432/ssau_schedule_bot

# Логи: рабочий уровень INFO, структурный json (под агрегаторы).
LOGGING__LEVEL=INFO
LOGGING__FORMAT=json

# Метрики Prometheus. Порты: API HTTP 3100, bot 3101, worker 3102, API metrics 3103.
METRICS__ENABLED=true
METRICS__HOST=0.0.0.0
METRICS__PORT=3103
TELEGRAM__METRICS_PORT=3101
WORKERS__METRICS_PORT=3102

# REST API (админ-ручки).
API__HOST=0.0.0.0
API__PORT=3100
API__METRICS_PORT=3103

# Telemetry (OTLP) и алерты — выключены (включить при необходимости).
TELEMETRY__ENABLED=false
ALERTS__ENABLED=false

# Шифр паролей — только Fernet (ключ в sensitive.env);
# plaintext не разрешаем (SECURITY__ALLOW_PLAINTEXT не задаём -> false).
